          "name": "Get Users by Role",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/users/role/LOAN_OFFICER", "host": ["{{baseUrl}}"], "path": ["api", "users", "role", "LOAN_OFFICER"] }
          }
        },
        {
          "name": "Get Users by Branch",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/users/branch/BR001", "host": ["{{baseUrl}}"], "path": ["api", "users", "branch", "BR001"] }
          }
        },
        {
          "name": "Assign Roles to User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/users/EMP001/roles", "host": ["{{baseUrl}}"], "path": ["api", "users", "EMP001", "roles"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"roleCodes\": [\"CREDIT_MANAGER\", \"LOAN_OFFICER\"]\n}"
            }
          }
        },
        {
          "name": "Remove Role from User",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/api/users/EMP001/roles/CREDIT_MANAGER", "host": ["{{baseUrl}}"], "path": ["api", "users", "EMP001", "roles", "CREDIT_MANAGER"] }
          }
        }
      ]
    },
