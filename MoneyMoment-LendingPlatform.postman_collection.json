{
  "info": {
    "name": "Money Moment - Lending Platform",
    "description": "Complete API collection for Money Moment Lending Platform. Base URL is set as a variable - switch between local and production easily.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "https://money-moment-lending.onrender.com",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Users",
      "item": [
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"employeeId\": \"EMP001\",\n  \"username\": \"john.doe\",\n  \"password\": \"password123\",\n  \"email\": \"john.doe@moneymoment.com\",\n  \"fullName\": \"John Doe\",\n  \"phone\": \"9876543210\",\n  \"department\": \"Loans\",\n  \"designation\": \"Loan Officer\",\n  \"branchCode\": \"BR001\",\n  \"regionCode\": \"SOUTH\",\n  \"managerEmployeeId\": null,\n  \"joiningDate\": \"2024-01-15\",\n  \"roleCodes\": [\"LOAN_OFFICER\"]\n}"
            }
          }
        },
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/api/users", "host": ["{{baseUrl}}"], "path": ["api", "users"] }
          }
        },
        {
          "name": "Get User by Employee ID",
